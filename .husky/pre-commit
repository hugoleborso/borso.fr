set -e

# Run the relevant @borso/* infra package's full test suite (including 100%
# coverage thresholds) whenever a commit touches its source. Cheap to skip
# when nothing under infra/ changed.
changed=$(git diff --cached --name-only --diff-filter=ACMR)

if echo "$changed" | grep -q '^infra/cdk/'; then
  echo "[pre-commit] infra/cdk/ changed — running @borso/infra test:coverage"
  pnpm --filter @borso/infra test:coverage
fi

if echo "$changed" | grep -q '^infra/shared/'; then
  echo "[pre-commit] infra/shared/ changed — running @borso/shared-infra test:coverage"
  pnpm --filter @borso/shared-infra test:coverage
fi
