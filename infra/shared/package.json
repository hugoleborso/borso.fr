{
  "name": "@borso/shared-infra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "synth": "cdk synth --all",
    "diff": "cdk diff --all",
    "deploy": "cdk deploy --all --require-approval never",
    "destroy": "cdk destroy --all --force",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@borso/infra": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.2.4",
    "aws-cdk": "^2.180.0",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
