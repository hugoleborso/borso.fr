{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["docs/**"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "ignoreBinaries": ["typecheck", "build"]
    },
    "apps/borso-fr": {
      "entry": [
        "bin/app.ts",
        "site/art/mondrian/main.tsx",
        "site/12-travaux/main.tsx",
        "site/**/*.utils.test.ts"
      ],
      "project": ["bin/**/*.ts", "site/**/*.ts", "site/**/*.tsx"]
    },
    "apps/borsouvertures": {
      "entry": ["bin/app.ts", "site/**/*.utils.test.ts"],
      "project": ["bin/**/*.ts", "scripts/**/*.ts", "site/**/*.ts", "site/**/*.tsx"]
    },
    "apps/last-loop-lepin": {
      "entry": [
        "cdk/bin/cdk.ts",
        "api/src/main.ts",
        "api/src/**/*.test.ts",
        "site/src/**/*.utils.test.ts",
        "test/**/*.ts"
      ],
      "project": [
        "cdk/**/*.ts",
        "site/src/**/*.ts",
        "site/src/**/*.tsx",
        "api/src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "infra/cdk": {
      "entry": [
        "src/index.ts",
        "src/internal/migration-runner/index.ts",
        "src/internal/cf-host-routing-function.code.js",
        "src/internal/cf-static-site-index-rewrite.code.js",
        "test/**/*.test.ts",
        "test/unit/fixtures/handler.ts"
      ],
      "ignoreDependencies": ["esbuild"]
    },
    "infra/shared": {
      "entry": ["bin/shared.ts", "test/unit/**/*.test.ts"],
      "project": ["bin/**/*.ts", "lib/**/*.ts", "test/**/*.ts"],
      "ignoreDependencies": ["tsx"]
    }
  }
}
