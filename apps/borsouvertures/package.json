{
  "name": "@borso-app/borsouvertures",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome lint",
    "typecheck": "tsc -p tsconfig.cdk.json --noEmit && tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:openings": "tsx scripts/build-openings.ts",
    "synth": "pnpm --filter @borso/infra run build && pnpm build && cdk synth --all",
    "diff": "pnpm --filter @borso/infra run build && pnpm build && cdk diff --all",
    "deploy": "pnpm --filter @borso/infra run build && pnpm build && cdk synth --all && ../../scripts/preflight-cloudfront-aliases.sh cdk.out && cdk deploy --all --require-approval never",
    "destroy": "cdk destroy --all --force"
  },
  "dependencies": {
    "@borso/infra": "workspace:*",
    "chess.js": "^1.0.0",
    "react": "^18.3.1",
    "react-chessboard": "^4.3.1",
    "react-dom": "^18.3.1",
    "workbox-window": "^7.4.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "aws-cdk": "^2.180.0",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8"
  }
}
