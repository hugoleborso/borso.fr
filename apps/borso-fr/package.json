{
  "name": "@borso-app/borso-fr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome lint",
    "typecheck": "tsc -p tsconfig.cdk.json --noEmit && tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "screenshot": "node scripts/screenshot.mjs",
    "synth": "pnpm --filter @borso/infra run build && pnpm build && cdk synth --all",
    "diff": "pnpm --filter @borso/infra run build && pnpm build && cdk diff --all",
    "deploy": "pnpm --filter @borso/infra run build && pnpm build && cdk synth --all && ../../scripts/preflight-cloudfront-aliases.sh cdk.out && cdk deploy --all --require-approval never",
    "destroy": "cdk destroy --all --force"
  },
  "dependencies": {
    "@borso/infra": "workspace:*",
    "@fontsource/cormorant-garamond": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@fontsource/playfair-display": "^5.1.0",
    "ogl": "1.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "aws-cdk": "^2.180.0",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "jsdom": "^25.0.1",
    "playwright": "^1.49.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
