{
  "name": "@borso-app/last-loop-lepin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch api/src/main.dev.ts",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome lint",
    "typecheck": "tsc -p tsconfig.cdk.json --noEmit && tsc --noEmit",
    "test:core": "vitest run --project core",
    "test": "vitest run --project back-e2e",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate:test": "tsx test/apply-migrations.ts",
    "synth": "pnpm --filter @borso/infra run build && pnpm build && cdk synth --all",
    "diff": "pnpm --filter @borso/infra run build && pnpm build && cdk diff --all",
    "deploy": "pnpm --filter @borso/infra run build && pnpm build && cdk synth --all && ../../scripts/preflight-cloudfront-aliases.sh cdk.out && cdk deploy --all --require-approval never",
    "destroy": "cdk destroy --all --force"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/dsql-signer": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "@borso/infra": "workspace:*",
    "@hono/zod-validator": "^0.4.0",
    "@sentry/react": "^8.50.0",
    "@tmcw/togeojson": "^7.1.0",
    "argon2": "^0.41.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "jose": "^5.9.6",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "aws-cdk": "^2.180.0",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "drizzle-kit": "^0.30.0",
    "jsdom": "^25.0.1",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
