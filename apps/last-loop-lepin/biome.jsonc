{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "root": false,
  "extends": ["../../biome.jsonc"],
  "plugins": [
    "../../biome-plugins/no-type-assertion-except-unknown.grit",
    "../../biome-plugins/no-inline-subscribe-in-use-sync-external-store.grit",
    "../../biome-plugins/no-direct-api-fetch-in-site.grit"
  ],
  "files": {
    "includes": ["api/**", "site/**", "cdk/**", "test/**", "bin/**"]
  },
  "overrides": [
    {
      "includes": ["**/*.controller.ts", "!**/__test/test-seed.controller.ts"],
      "plugins": ["../../biome-plugins/no-controller-imports-outside-service.grit"]
    }
  ]
}
