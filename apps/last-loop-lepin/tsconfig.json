{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "@site/*": ["site/src/*"],
      "@api/*": ["api/src/*"]
    }
  },
  "include": [
    "site/src/**/*.ts",
    "site/src/**/*.tsx",
    "api/src/**/*.ts",
    "test/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "drizzle.config.ts"
  ]
}
